<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LearnWithCircle.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LearnWithCircle"
    Title="LearnWithCircle"
    
    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
    TitleColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource OnSurfaceDark}}">

    <ShellContent
        Title="LearnWithCircle"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Video Tutorial"
        ContentTemplate="{DataTemplate local:VideoPage}"
        Route="VideoPage" />

    <ShellContent
        Title="License"
        ContentTemplate="{DataTemplate local:LicensePage}"
        Route="License" />

</Shell>
