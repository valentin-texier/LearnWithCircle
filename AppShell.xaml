<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LearnWithCircle.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LearnWithCircle"
    Title="تعليم العربية بالدوائر"
    
    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
    TitleColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource OnSurfaceDark}}"
    ForegroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource OnSurfaceDark}}">

    <ShellContent
        Title="تعليم العربية بالدوائر"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <MenuItem Text="الدروس المُصوَّرة" Clicked="OnGettingStartedClicked" />

    <MenuItem Text="عرض الرخصة" Clicked="OnLicenseClicked" />

    <MenuItem Text="تعرَّف المشروع" Clicked="OnWikipediaClicked" />

    <MenuItem Text="تطبيق الأستاذ" Clicked="OnTeacherClicked" />


</Shell>
