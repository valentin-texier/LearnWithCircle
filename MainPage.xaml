<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:learning="clr-namespace:LearnWithCircle.LearningCircles"
    x:Class="LearnWithCircle.MainPage"
    Style="{StaticResource MainPageStyle}">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="0">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="24"
                             Padding="16,20">
            <Border Style="{StaticResource HeaderBorder}">
                <VerticalStackLayout VerticalOptions="Center"
                                     Spacing="6">
                    <Label x:Name="TitleLabel"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           Style="{StaticResource Headline}"/>
                    <Label x:Name="SubtitleLabel"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           Style="{StaticResource SubHeadline}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              RowDefinitions="*,Auto"
              Padding="0">
            <CarouselView x:Name="LearningCircleCarousel"
                          HeightRequest="420"
                          PeekAreaInsets="40,0"
                          HorizontalScrollBarVisibility="Never"
                          CurrentItemChanged="OnCurrentItemChanged"
                          Loop="False"
                          Margin="0,10,0,0"
                          Grid.Row="0">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="learning:LearningCircleModel">
                        <Grid x:Name="OverlayGrid"
                              HorizontalOptions="Fill"
                              VerticalOptions="Center">

                            <Image Source="{Binding SvgFile}"
                                   WidthRequest="300"
                                   HeightRequest="300"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCircleTapped"/>
                                </Image.GestureRecognizers>
                            </Image>

                            <Border x:Name="OverlayLabel"
                                    BackgroundColor="#86000000"
                                    WidthRequest="100"
                                    HeightRequest="100"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    IsVisible="True">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="50"/>
                                </Border.StrokeShape>
                                <Label Text="Tap me"
                                       TextColor="White"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="0,20,0,20"
                                 Grid.Row="1">
                <Label Text="Need some help?"
                       HorizontalOptions="Center"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"/>

                <Button Text="Watch Tutorial"
                        HorizontalOptions="Center"
                        FontSize="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryDark}}"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="16,10"
                        Clicked="OnTutorialClicked"/>
            </VerticalStackLayout>
        </Grid>

        <Label Grid.Row="2"
               Text="© 2026 LearnWithCircle"
               Style="{StaticResource FooterLabel}"/>
    </Grid>
</ContentPage>