<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:learning="clr-namespace:LearnWithCircle.LearningCircles"
    x:Class="LearnWithCircle.MainPage"
    BackgroundColor="{StaticResource White}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <VerticalStackLayout Grid.Row="0" Spacing="24" Padding="16,20">
            <Border Style="{StaticResource HeaderBorder}">
                <VerticalStackLayout VerticalOptions="Center" Spacing="6">
                    <Label x:Name="TitleLabel"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           Style="{StaticResource Headline}" />
                    <Label x:Name="SubtitleLabel"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           Style="{StaticResource SubHeadline}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="20" Padding="0">

            <CarouselView x:Name="LearningCircleCarousel"
                          HeightRequest="420"
                          PeekAreaInsets="40,0"
                          HorizontalScrollBarVisibility="Never"
                          CurrentItemChanged="OnCurrentItemChanged"
                          Loop="False"
                          Margin="0,10,0,0">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="learning:LearningCircleModel">
                        <Grid HorizontalOptions="Fill" VerticalOptions="Center">
                            <Image Source="{Binding SvgFile}"
                                   WidthRequest="300"
                                   HeightRequest="300"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <Label HorizontalOptions="Center"
                FontSize="14"
                Margin="0,20,0,0">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Need some help? " 
                            TextColor="{StaticResource Gray900}" />

                        <Span Text="Check out the tutorial"
                            TextColor="{StaticResource Primary}"
                            TextDecorations="Underline">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTutorialTapped" />
                            </Span.GestureRecognizers>
                        </Span>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>

        <Label Grid.Row="2"
            Text="© 2026 LearnWithCircle"
            Style="{StaticResource FooterLabel}" />

    </Grid>
</ContentPage>
