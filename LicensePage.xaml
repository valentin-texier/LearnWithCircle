<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearnWithCircle.LicensePage"
             Style="{StaticResource MainPageStyle}"
             Title="عرض الرخصة">

       <ScrollView>
              <VerticalStackLayout Padding="16,20"
                                   Spacing="16">

                     <Border Style="{StaticResource HeaderBorder}">
                            <Grid VerticalOptions="Fill">
                                   <VerticalStackLayout Padding="16,12"
                                                        Spacing="6"
                                                        VerticalOptions="Center">
                                          <Label Text="رُخصة المشاع الإبداعي"
                                                 Style="{StaticResource Headline}"
                                                 MaxLines="2"
                                                 LineBreakMode="TailTruncation"/>
                                          <Label Text="CC BY 4.0 — المُلزِمة بنسب العمل لمؤلِّفه M. Bakni"
                                                 Style="{StaticResource SubHeadline}"
                                                 MaxLines="2"
                                                 LineBreakMode="TailTruncation"/>
                                   </VerticalStackLayout>
                            </Grid>
                     </Border>

                     <Label Text="مجموعة المعطيات هذه مُرخَّصة برُخصة المشاع الإبداعي الدولية المُلزِمة بنسب العمل لمؤلِّفه (CC BY 4.0)"
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Text="يمكنك:"
                            Style="{StaticResource SectionTitleStyle}"/>

                     <Label Text="المشاركة: أي نسخ وإعادة توزيع المادة بأي وسيلة أو تنسيق."
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Text="التعديل: إعادة إنتاج أو عمل تغيير أو بناء معطيات جديدة انطلاقًا من هذه المادة، بما في ذلك الاستعمال التجاري."
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Text="وفقًا للشروط التالية:"
                            Style="{StaticResource SectionTitleStyle}"/>

                     <Label Text="النسبة: يلزم ذكر المؤلِّف المناسب، ووضع رابط إلى الرخصة، والإشارة إلى أي تغييرات أُجريت. لا قيود صارمة على كيفية نسبة العمل، ما خلا عدم الإيحاء بأن مؤلف العمل يؤيدك أو يؤيد استخدامك."
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Text="عدم فرض قيود إضافية — لا يجوز تطبيق شروط قانونية أو تدابير تقنية تقيّد الآخرين من استخدام مجموعة المعطيات كما تسمح به الرُخصة."
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Text="يُمكن قراءة النص الكامل للرخصة لمزيد من التفاصيل:"
                            Style="{StaticResource BodyBoldStyle}"/>

                     <Label Padding="4,0">
                            <Label.GestureRecognizers>
                                   <TapGestureRecognizer Tapped="OnLinkTapped"/>
                            </Label.GestureRecognizers>
                            <Label.FormattedText>
                                   <FormattedString>
                                          <Span Text="https://creativecommons.org/licenses/by/4.0/legalcode"
                                                FontSize="14"
                                                TextColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                         Dark={StaticResource PrimaryDark}}"
                                                TextDecorations="Underline"/>
                                   </FormattedString>
                            </Label.FormattedText>
                     </Label>

                     <Label HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource FooterLabel}"
                            Margin="0,16,0,0"
                            Text="CC BY 4.0 2026 تعليم العربية بالدوائر"/>

              </VerticalStackLayout>
       </ScrollView>
</ContentPage>