{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build MAUI App",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "dotnet build -t:Run -f net9.0-android"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start Pixel_5 Emulator",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "cd 'C:\\Users\\valentin.texier\\AppData\\Local\\Android\\Sdk\\emulator'; ./emulator -avd pixel_5"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
