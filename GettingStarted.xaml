<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="LearnWithCircle.GettingStarted"
    Title="البدء"
    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="16">
            <Label Text="الدروس المصورة"
                Style="{StaticResource Headline}"
                HorizontalTextAlignment="Center" />

            <Label Text="تسجيلات تعرُّف كيفية استعمال التطبيق"
                Style="{StaticResource SubHeadline}"
                HorizontalTextAlignment="Center" />
                
            <VerticalStackLayout Spacing="16" HorizontalOptions="Center" Margin="0,20,0,0">
                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=BkPuuFP6SCc" />

                <ImageButton
                    Source="https://img.youtube.com/vi/__C_N5OZC0c/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=__C_N5OZC0c" />

                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=mnvIv9uncC8" />

                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=1jL5NiClv6Q" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
