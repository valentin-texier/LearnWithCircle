<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="LearnWithCircle.GettingStarted"
    Title="البدء"
    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="OnBackClicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Glyph="&#x2190;" Size="30" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid RowDefinitions="Auto,*">
            <VerticalStackLayout Grid.Row="0"
                                 x:Name="HeaderSection"
                                 Spacing="24"
                                 Padding="16,20">
                <Border x:Name="HeaderBorder"
                        HeightRequest="-1"
                        Style="{StaticResource HeaderBorder}">
                    <VerticalStackLayout VerticalOptions="Center"
                                         Spacing="6"
                                         Padding="16,12">
                        <Label x:Name="TitleLabel"
                               Text="الدروس المصورة"
                               LineBreakMode="WordWrap"
                               Style="{StaticResource Headline}"
                               HorizontalTextAlignment="Center"/>
                        <Label x:Name="SubtitleLabel"
                               Text="تسجيلات تعرُّف كيفية استعمال التطبيق"
                               LineBreakMode="WordWrap"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <FlexLayout Grid.Row="1"
                        x:Name="VideoLayout"
                        Wrap="Wrap"
                        JustifyContent="Center"
                        Direction="Row"
                        Padding="8">
                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Margin="8"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=BkPuuFP6SCc" />

                <ImageButton
                    Source="https://img.youtube.com/vi/__C_N5OZC0c/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Margin="8"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=__C_N5OZC0c" />

                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Margin="8"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=mnvIv9uncC8" />

                <ImageButton
                    Source="https://img.youtube.com/vi/BkPuuFP6SCc/0.jpg"
                    Aspect="AspectFill"
                    HeightRequest="180"
                    WidthRequest="320"
                    Margin="8"
                    Clicked="OnVideoClicked"
                    CommandParameter="https://www.youtube.com/watch?v=1jL5NiClv6Q" />
            </FlexLayout>
        </Grid>
    </ScrollView>

</ContentPage>
