<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LearnWithCircle.Controls"
    xmlns:learning="clr-namespace:LearnWithCircle.LearningCircles"
    x:Class="LearnWithCircle.LearningCircleDetailPage"
    x:DataType="learning:LearningCircleModel"
    BackgroundColor="{StaticResource White}">

    <Grid>
        <controls:ThreeFingerImage x:Name="WheelImage"
                                   Source="{Binding SvgFile}"
                                   WidthRequest="320"
                                   HeightRequest="320"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   AnchorX="0.5"
                                   AnchorY="0.5"
                                   ThreeFingerTapped="OnThreeFingerTapped">
            <controls:ThreeFingerImage.GestureRecognizers>
                <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
            </controls:ThreeFingerImage.GestureRecognizers>
        </controls:ThreeFingerImage>
    </Grid>
</ContentPage>
