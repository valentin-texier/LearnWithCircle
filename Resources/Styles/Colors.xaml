<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Light -->
    <Color x:Key="PrimaryLight">#4D61FF</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceVariantLight">#EEF0FF</Color>
    <Color x:Key="OnSurfaceLight">#1C1B1F</Color>
    <Color x:Key="OnSurfaceVariantLight">#5F6368</Color>
    <Color x:Key="Gray300Light">#ACACAC</Color>
    <Color x:Key="Gray400Light">#919191</Color>
    <Color x:Key="Gray600Light">#404040</Color>
    <Color x:Key="Gray900Light">#212121</Color>

    <!-- Dark -->
    <Color x:Key="PrimaryDark">#9AA4FF</Color>
    <Color x:Key="SurfaceDark">#121212</Color>
    <Color x:Key="SurfaceVariantDark">#30303F</Color>
    <Color x:Key="OnSurfaceDark">#E6E6E6</Color>
    <Color x:Key="OnSurfaceVariantDark">#B0B3C6</Color>
    <Color x:Key="Gray300Dark">#6E6E6E</Color>
    <Color x:Key="Gray400Dark">#6E6E6E</Color>
    <Color x:Key="Gray600Dark">#B0B3C6</Color>
    <Color x:Key="Gray900Dark">#FFFFFF</Color>

    <Color x:Key="ColorWhite">#FFFFFF</Color>
    <Color x:Key="ColorOverlayBackground">#A6000000</Color>

</ResourceDictionary>